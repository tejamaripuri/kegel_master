{
  "@@locale": "en",
  "learnAppBarTitle": "Learn",
  "learnShellDisclaimer": "This area is educational wellness information. It is not medical advice and not a substitute for care from a qualified clinician.",
  "learnCatheterBannerBody": "Pelvic floor exercises are suspended while you use a catheter. Educational content only — follow your care team.",
  "learnFoundationSectionTitle": "Foundation",
  "learnFoundationWhatPelvicFloorTitle": "What the pelvic floor does",
  "learnFoundationWhatPelvicFloorBody": "These muscles help support your organs and play a role in bladder and bowel control. People notice them most when coughing, laughing, lifting, or rushing to the bathroom.",
  "learnFoundationCoordinationTitle": "Coordination matters as much as strength",
  "learnFoundationCoordinationBody": "Healthy control is often about timing and relaxation, not only squeezing harder. If everything feels tight or braced all day, gentle down-training and pacing can be more helpful than adding more force.",
  "learnFoundationProgressTitle": "Progress is uneven for most people",
  "learnFoundationProgressBody": "Some weeks feel easier and some feel messy. That pattern is common. Use how you feel as a guide, and pause or simplify when symptoms flare rather than pushing through.",
  "learnFoundationCareTeamTitle": "Stay aligned with your care team",
  "learnFoundationCareTeamBody": "Bring questions about pain, new symptoms, or catheter changes to the clinician who knows your situation. This app supports habit building; it does not replace individualized guidance.",
  "learnAnatomySectionTitle": "Anatomy track",
  "learnAnatomySectionIntro": "Choose the pelvic cues that fit your body. This is about structure and typical clinical patterns — not who you are.",
  "learnAnatomyTrackMaleTypicalLabel": "Male-typical pelvic cues",
  "learnAnatomyTrackFemaleTypicalLabel": "Female-typical pelvic cues",
  "learnAnatomyPromptSelectTrack": "Pick the anatomy track that matches the pelvic cues you want to work with.",
  "learnAnatomyMaleTypicalBody": "For male-typical pelvic anatomy, focus on lifting around the base of the penis and the area between the scrotum and anus. A gentle squeeze should feel like you are drawing upward without gripping the belly or thighs. Release fully between reps so the muscles do not stay braced.",
  "learnAnatomyFemaleTypicalBody": "For female-typical pelvic anatomy, focus on a lift around the vaginal opening and the area toward the anus. Imagine picking up a marble without squeezing the buttocks or inner thighs. Let the muscles soften completely between reps.",
  "learnAnatomyPrivacyExpansionTitle": "Optional: tactile check",
  "learnAnatomyMaleTypicalPrivacyBody": "With clean hands, you can lightly press the perineum (between scrotum and anus) while you contract. You should feel a subtle lift, not a hard brace. Stop if you feel pain.",
  "learnAnatomyFemaleTypicalPrivacyBody": "With clean hands, you can place one finger at the vaginal opening while you contract. You should feel a gentle inward lift, not a painful squeeze. Stop if you feel pain.",
  "learnDosDontsSectionTitle": "Dos and don'ts",
  "learnDosDontsSectionIntro": "Simple habits that keep training safer and more effective.",
  "learnDosDontsDoSubgroupTitle": "Do",
  "learnDosDontsDontSubgroupTitle": "Don't",
  "learnDosDontsReleaseBetweenRepsText": "Let the pelvic floor fully release between reps. Muscles should not stay braced after each squeeze.",
  "learnDosDontsBreatheNormallyText": "Keep breathing normally while you contract and release. Do not hold your breath to squeeze harder.",
  "learnDosDontsStartShortSetsText": "Start with short, easy sets and add volume only when form and comfort stay steady.",
  "learnDosDontsStopOnFlareText": "Stop or simplify when symptoms flare. A lighter session today beats pushing through and feeling worse tomorrow.",
  "learnDosDontsNoPainThroughText": "Do not push through sharp, burning, or worsening pain. Stop and get clinician guidance if pain keeps returning.",
  "learnDosDontsNoCompensateText": "Do not squeeze your glutes, inner thighs, or belly to fake a stronger lift. That pattern often makes symptoms worse.",
  "learnDosDontsNoCatheterTrainText": "Do not use this app for pelvic floor exercise while a catheter is in place. Follow your care team's instructions instead.",
  "learnDosDontsNoSubstituteClinicianText": "Do not treat this app as a substitute for professional advice when you have new pain, bleeding, fever, or sudden control changes."
}
